<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <p>products</p>
    <% products.foreach(p=>{ %>
    <%= p.id %>
    <%= p.name %>
    <%= p.price %>
        <% }) %>

        <table>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price</th>
            </tr>
            <% products.foreach(p=>{ %>
                <tr>
                    
                    <td><%=p.id %></td>
                    <td><%=p.name %></td>
                    <td><%=p.price %></td>
                     <% }) %>
                </tr>
                
        </table>

</body>
</html>